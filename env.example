# Arquivo de exemplo para variáveis de ambiente
# Copie este arquivo para .env e configure os valores

# Configurações da aplicação Flask
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=sua-chave-secreta-muito-forte-aqui

# Segurança (CSRF)
WTF_CSRF_ENABLED=True
WTF_CSRF_TIME_LIMIT=3600
WTF_CSRF_SSL_STRICT=False

# Configurações de e-mail (formulário de contato)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app
MAIL_DEFAULT_SENDER=seu-email@gmail.com

# Banco de dados MySQL (blog e funcionalidades administrativas)
DB_PASSWORD=sua-senha-do-banco

# PythonAnywhere (produção)
PYTHONANYWHERE_DOMAIN=paixaodecristomaracanau.pythonanywhere.com

# Upload de imagens
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=app/static/images/blog
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp

# Configurações do projeto
PROJECT_NAME=Paixão de Cristo de Maracanaú
PROJECT_PRONAC=255599
PROJECT_YEAR=2026
PROJECT_DIRECTOR=Celso Custódio
PROJECT_PHONE=(85) 92002-1207
PROJECT_EMAIL=contato@teatroalmirdutra.com.br
